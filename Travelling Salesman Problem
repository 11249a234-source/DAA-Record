#include <stdio.h>
#include <stdlib.h>
#define MAX 25

int matrix[MAX][MAX], visited[MAX], n, cost = 0;

int nearest(int c){
    int i, min = 1e9, idx = -1;
    for(i = 0; i < n; ++i)
        if(matrix[c][i] && !visited[i] && matrix[c][i] < min){
            min = matrix[c][i]; idx = i;
        }
    if(idx != -1) cost += matrix[c][idx];
    return idx;
}

void tsp(int start){
    int cur = start, nxt;
    visited[cur] = 1;
    printf("%d ", cur + 1);
    while((nxt = nearest(cur)) != -1){
        printf("%d ", nxt + 1);
        visited[nxt] = 1;
        cur = nxt;
    }
    printf("%d", start + 1);
    cost += matrix[cur][start];
}

int main(void){
    int i, j;
    printf("Enter total number of cities: ");
    if(scanf("%d", &n) != 1) return 0;
    if(n < 1 || n > MAX){
        printf("Invalid number of cities (1-%d)\n", MAX);
        return 0;
    }
    for(i = 0; i < n; ++i){
        printf("Enter %d elements for row %d (space-separated):\n", n, i + 1);
        for(j = 0; j < n; ++j){
            while(scanf("%d", &matrix[i][j]) != 1){
                printf("Invalid input; please enter integers only: ");
                int c = getchar();
                while(c != '\n' && c != EOF) c = getchar();
            }
        }
        visited[i] = 0;
    }
    printf("\nEntered Cost Matrix\n");
    for(i = 0; i < n; ++i){
        for(j = 0; j < n; ++j) printf("%d ", matrix[i][j]);
        printf("\n");
    }
    printf("\nPath:\t");
    tsp(0);
    printf("\n\nMinimum Cost:\t%d\n", cost);
    return 0;
}
